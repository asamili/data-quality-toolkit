# But keep example files
!examples/*.csv
!examples/**/*.csv
!examples/*.json
!tests/fixtures/*.csv
!tests/fixtures/*.json

# Runtime/generated line-delimited JSON artifacts (e.g. quality_history.jsonl, telemetry.jsonl)
